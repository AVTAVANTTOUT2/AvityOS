# AvityOS environment — names only, never commit real values.

# Control plane
AVITY_DB_PATH=            # default: ~/.avity/avity.sqlite
AVITY_PORT=               # default: 7717
AVITY_HOST=               # default: 127.0.0.1
AVITY_API_TOKEN=          # optional bearer token required by the API when set
AVITY_MAX_CONCURRENT_RUNS=
AVITY_MAX_CONCURRENT_RUNS_PER_PROJECT=

# Worker
AVITY_CONTROL_PLANE_URL=  # default: http://127.0.0.1:7717
AVITY_WORKER_NAME=
AVITY_WORKER_ID=          # printed once at enrollment
AVITY_WORKER_TOKEN=       # printed once at enrollment; store securely
AVITY_WORKER_POLL_MS=
AVITY_WORKER_CAPABILITIES=

# Web
VITE_AVITY_API=           # default: http://127.0.0.1:7717
VITE_AVITY_DEMO=          # set to 1 to force demo fixtures

# Provider credentials (only needed for real providers; fake needs none)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
