# AvityOS environment — names only, never commit real values.

# Control plane
AVITY_DB_PATH=            # default: ~/.avity/avity.sqlite
AVITY_PORT=               # default: 7717
AVITY_HOST=               # default: 127.0.0.1
AVITY_API_TOKEN=          # bearer token; auto-generated to ~/.avity/api-token if unset
AVITY_API_TOKEN_PATH=     # where the generated token is stored (default ~/.avity/api-token)
AVITY_ALLOWED_ORIGINS=    # comma list; default http://localhost:5173,http://127.0.0.1:5173
AVITY_MAX_CONCURRENT_RUNS=
AVITY_MAX_CONCURRENT_RUNS_PER_PROJECT=

# Provider chain and models (ADR-0005). Only providers with creds are registered.
AVITY_PROVIDER_CHAIN=     # e.g. openai,anthropic,fake
AVITY_DEFAULT_MODELS=     # e.g. openai=gpt-4o,anthropic=claude-sonnet-4-5,fake=fake:code
AVITY_REVIEW_MODELS=      # reviewer models, distinct identity, e.g. anthropic=claude-opus-4-8
OPENAI_API_KEY=
AVITY_OPENAI_BASE_URL=
AVITY_OPENAI_MODELS=
DEEPSEEK_API_KEY=
AVITY_DEEPSEEK_BASE_URL=
AVITY_DEEPSEEK_MODELS=
ANTHROPIC_API_KEY=
AVITY_ANTHROPIC_BASE_URL=
AVITY_ANTHROPIC_MODELS=
AVITY_CLAUDE_CODE_BIN=    # path to the claude executable (non-interactive -p mode)
AVITY_CURSOR_BIN=         # path to cursor-agent

# Worker
AVITY_CONTROL_PLANE_URL=  # default: http://127.0.0.1:7717 (https required off-loopback)
AVITY_WORKER_NAME=
AVITY_WORKER_ID=          # printed once at enrollment
AVITY_WORKER_TOKEN=       # printed once at enrollment; store securely
AVITY_WORKER_POLL_MS=
AVITY_WORKER_CAPABILITIES=
AVITY_ALLOW_INSECURE=     # set 1 to permit plain HTTP off-loopback (not recommended)

# Web
VITE_AVITY_API=           # default: http://127.0.0.1:7717
VITE_AVITY_DEMO=          # set to 1 to force demo fixtures
