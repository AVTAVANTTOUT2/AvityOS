{
  "name": "@avityos/remote-relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "avity-remote-relay": "./dist/main.js"
  },
