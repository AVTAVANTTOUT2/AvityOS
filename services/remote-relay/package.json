    "test": "vitest run"
  },
  "dependencies": {
    "@avityos/contracts": "workspace:*",
    "fastify": "5.10.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@avityos/remote-bridge": "workspace:*",
    "@types/node": "22.20.1",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
