{
  "name": "@avityos/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "avity-control-plane": "./bin/avity-control-plane.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --no-file-parallelism",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@avityos/contracts": "workspace:*",
    "@avityos/git": "workspace:*",
    "@avityos/orchestration": "workspace:*",
    "@avityos/policy": "workspace:*",
    "@avityos/providers": "workspace:*",
    "@avityos/remote-bridge": "workspace:*",
    "@fastify/cors": "10.1.0",
    "fastify": "5.10.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
