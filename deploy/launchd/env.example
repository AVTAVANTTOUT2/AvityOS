# Example environment file for AvityOS launchd services.
# Copy to an external path outside the repository, then fill in real values.
#
#   cp deploy/launchd/env.example ~/.config/avityos/control-plane.env
#   cp deploy/launchd/env.example ~/.config/avityos/worker.env
#   chmod 600 ~/.config/avityos/control-plane.env
#   chmod 600 ~/.config/avityos/worker.env
#
# Never commit the real files. Protect them with chmod 600.

# Shared paths (replace with absolute paths on the target Mac)
AVITY_ROOT=/absolute/path/to/AvityOS
NODE_BINARY=/absolute/path/to/node
AVITY_LOG_DIR=/absolute/path/to/logs

# Control plane (services/control-plane/dist/main.js)
AVITY_DB_PATH=/absolute/path/to/avity.sqlite
AVITY_HOST=127.0.0.1
AVITY_PORT=7717
AVITY_API_TOKEN=replace-with-a-random-token
AVITY_API_TOKEN_PATH=/absolute/path/to/api-token
AVITY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AVITY_MAX_CONCURRENT_RUNS=
AVITY_MAX_CONCURRENT_RUNS_PER_PROJECT=

# Optional provider configuration (placeholders only — put real secrets in the chmod 600 env file)
AVITY_PROVIDER_CHAIN=fake
AVITY_DEFAULT_MODELS=fake=fake:code
AVITY_REVIEW_MODELS=fake=fake:review-approve
# OPENAI_API_KEY=replace-with-provider-secret
# ANTHROPIC_API_KEY=replace-with-provider-secret
# CLAUDE_CODE_OAUTH_TOKEN=replace-with-setup-token
# DEEPSEEK_API_KEY=replace-with-provider-secret
# CURSOR_API_KEY=replace-with-provider-secret

# Worker (services/worker/dist/main.js)
AVITY_CONTROL_PLANE_URL=http://127.0.0.1:7717
AVITY_WORKER_NAME=local-worker
# Optional secure credentials channel (owner-only file, auto-created on first enrollment).
AVITY_WORKER_CREDENTIALS_PATH=/absolute/path/to/worker-credentials.json
AVITY_WORKER_ID=replace-with-enrolled-worker-id
AVITY_WORKER_TOKEN=replace-with-a-random-token
AVITY_WORKER_POLL_MS=1000
AVITY_WORKER_CAPABILITIES=shell,git,node
AVITY_WORKER_MAX_CONCURRENT_RUNS=4
# AVITY_ALLOW_INSECURE=0

# Bounded wait used by deploy/launchd/run-worker.sh before exec
AVITY_HEALTH_MAX_ATTEMPTS=30
AVITY_HEALTH_RETRY_SECONDS=2
