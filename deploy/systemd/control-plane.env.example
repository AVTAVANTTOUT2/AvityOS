# AvityOS control plane — EnvironmentFile example for systemd.
# Copy to a path outside the git tree (e.g. /etc/avityos/control-plane.env),
# replace every placeholder, then protect the real file:
#   sudo chmod 600 /etc/avityos/control-plane.env
# Never commit the real file. Never put secrets in the .service unit.
# Format: KEY=value (no "export"). Lines starting with # are comments.

NODE_ENV=production

# SQLite database path (WAL/SHM siblings are created next to this file).
AVITY_DB_PATH=__AVITY_DATA_DIR__/avity.sqlite

# Bind address — keep loopback unless a reverse proxy terminates TLS in front.
AVITY_HOST=127.0.0.1
AVITY_PORT=7717

# Long random bearer token required by the API (except /v1/health).
# Generate e.g.: openssl rand -hex 32
AVITY_API_TOKEN=replace-with-a-random-token

# Optional: persist an auto-generated token if AVITY_API_TOKEN is unset.
# Prefer setting AVITY_API_TOKEN explicitly in production.
#AVITY_API_TOKEN_PATH=__AVITY_DATA_DIR__/api-token

# Optional CORS allow-list (comma-separated). Defaults target local Vite.
#AVITY_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional concurrency caps.
#AVITY_MAX_CONCURRENT_RUNS=4
#AVITY_MAX_CONCURRENT_RUNS_PER_PROJECT=2

# Optional provider chain / model maps (only providers with credentials register).
#AVITY_PROVIDER_CHAIN=openai,anthropic,fake
#AVITY_DEFAULT_MODELS=openai=gpt-4o,anthropic=claude-sonnet-4-5,fake=fake:code
#AVITY_REVIEW_MODELS=anthropic=claude-opus-4-8
#AVITY_ROLE_PROVIDERS=frontend=cursor|codex,backend=claude-code|codex

# Optional provider credentials / binaries (placeholders only — never commit real keys).
#OPENAI_API_KEY=replace-with-provider-key
#AVITY_OPENAI_BASE_URL=https://api.openai.com/v1
#AVITY_OPENAI_MODELS=
#DEEPSEEK_API_KEY=replace-with-provider-key
#AVITY_DEEPSEEK_BASE_URL=https://api.deepseek.com
#AVITY_DEEPSEEK_MODELS=
#ANTHROPIC_API_KEY=replace-with-provider-key
#CLAUDE_CODE_OAUTH_TOKEN=replace-with-setup-token
#AVITY_ANTHROPIC_BASE_URL=https://api.anthropic.com
#AVITY_ANTHROPIC_MODELS=
#AVITY_CLAUDE_CODE_BIN=/usr/local/bin/claude
#AVITY_CLAUDE_CODE_MODELS=
#AVITY_CODEX_BIN=/usr/local/bin/codex
#AVITY_CODEX_MODELS=
#CODEX_API_KEY=replace-with-provider-key
#AVITY_CURSOR_BIN=/usr/local/bin/cursor-agent
#AVITY_CURSOR_MODELS=
#CURSOR_API_KEY=replace-with-provider-key
#AVITY_COMMAND_BIN=
#AVITY_COMMAND_ARGS_JSON=
#AVITY_COMMAND_MODELS=
#AVITY_COMMAND_WORKSPACE_EDITS=0
