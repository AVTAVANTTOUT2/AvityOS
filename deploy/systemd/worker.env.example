# AvityOS worker — EnvironmentFile example for systemd.
# Copy to a path outside the git tree (e.g. /etc/avityos/worker.env),
# replace every placeholder, then protect the real file:
#   sudo chmod 600 /etc/avityos/worker.env
# Never commit the real file. Never put secrets in the .service unit.
# Format: KEY=value (no "export"). Lines starting with # are comments.

NODE_ENV=production

# Control plane base URL (https required off-loopback).
AVITY_CONTROL_PLANE_URL=http://127.0.0.1:7717

# Worker credentials:
# - preferred: owner-only credentials file (AVITY_WORKER_CREDENTIALS_PATH), no token output on startup
# - fallback: explicit AVITY_WORKER_ID / AVITY_WORKER_TOKEN variables
AVITY_WORKER_ID=replace-with-enrolled-worker-id
AVITY_WORKER_TOKEN=replace-with-a-random-token
# Optional secure credentials channel (owner-only file, auto-created on first enrollment).
#AVITY_WORKER_CREDENTIALS_PATH=/etc/avityos/worker-credentials.json

# Optional display name used at enrollment if ID/token are absent.
#AVITY_WORKER_NAME=avity-worker-1

# Optional polling / capacity tuning.
#AVITY_WORKER_POLL_MS=1000
#AVITY_WORKER_CAPABILITIES=shell,git,node
#AVITY_WORKER_MAX_CONCURRENT_RUNS=4

# Admin bearer — only needed for first enrollment when ID/token are unset.
#AVITY_API_TOKEN=replace-with-a-random-token

# Escape hatch: allow plain HTTP to a non-loopback control plane (not recommended).
#AVITY_ALLOW_INSECURE=0
